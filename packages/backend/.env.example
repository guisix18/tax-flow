# Fornecida automaticamente pelo add-on PostgreSQL do Railway
DATABASE_URL="postgresql://user:password@host:5432/railway"

# Segredo para assinar os JWT — gere com: openssl rand -hex 32
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"

# Brevo — gere em app.brevo.com > Settings > API Keys
BREVO_API_KEY="xkeysib-xxxxxxxxxxxxxxxxxxxx"
# Remetente — qualquer e-mail (não exige domínio verificado no plano gratuito)
BREVO_FROM_EMAIL="noreply@seudominio.com"
BREVO_FROM_NAME="Tax Flow"

# Opcional: quantos dias antes do vencimento enviar lembrete (padrão 3)
REMINDER_DAYS_AHEAD=3

# Railway define PORT automaticamente — não precisa configurar
# PORT=3333

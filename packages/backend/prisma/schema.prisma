// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  email         String    @unique
  password_hash String
  created_at    DateTime  @default(now())
  updated_at    DateTime?

  companies     Company[]
}

model Company {
  id             Int      @id @default(autoincrement())
  name           String
  cnpj           String?  @unique
  user_id        Int
  created_at     DateTime @default(now())
  updated_at     DateTime?

  user           User           @relation(fields: [user_id], references: [id])
  serviceOrders  ServiceOrder[]

  @@index([user_id])
}

model ServiceOrder {
  id                   Int              @id @default(autoincrement())
  company_id           Int
  service_name         String
  amount               Int
  
  due_date             DateTime
  service_status       ServiceStatus    @default(PENDING)
  note_issued          Boolean          @default(false)
  notified             Boolean          @default(false)
  notification_count   Int              @default(0)
  last_notification_at DateTime?
  
  created_at           DateTime         @default(now())
  updated_at           DateTime?
  company              Company          @relation(fields: [company_id], references: [id])

  @@index([company_id])
  @@index([note_issued, due_date])
}


enum ServiceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}